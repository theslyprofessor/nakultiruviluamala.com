---
import PageLayout from "@/layouts/PageLayout.astro";
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import {
  SITE_CONFIG,
  ROLES,
  EXPERTISE,
  PROJECTS,
  MUSIC_PROJECTS,
  BIO
} from "@/lib/constants";
import { Music, Mic, Code, GraduationCap, ExternalLink, ArrowRight, Mail, MapPin, Film, Radio, Disc3, Globe } from "lucide-react";
---

<PageLayout>
  <!-- Hero Section -->
  <section class="gradient-hero min-h-screen flex items-center pt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="flex flex-wrap gap-3 mb-8">
            {ROLES.map((role) => {
              const iconMap = { Music, Mic, Code, GraduationCap };
              const Icon = iconMap[role.icon as keyof typeof iconMap];
              return (
                <Badge variant="outline" className="px-4 py-2 text-sm flex items-center gap-2">
                  <Icon className="h-4 w-4" />
                  {role.title}
                </Badge>
              );
            })}
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight mb-6">
            <span class="text-foreground">Hi, I'm </span>
            <span class="gradient-text">Nakul</span>
          </h1>
          <p class="text-xl text-muted-foreground mb-6 max-w-2xl">
            {BIO.short} I create at the intersection of music, technology, and education,
            helping artists and students find their creative voice.
          </p>

          <!-- Southwestern Recording callout -->
          <a
            href="https://southwesternrecording.com"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-3 mb-8 px-5 py-3 rounded-xl bg-primary/10 border border-primary/20 hover:border-primary/40 hover:bg-primary/15 transition-all"
          >
            <Globe className="h-5 w-5 text-primary shrink-0" />
            <span class="text-sm font-medium text-foreground">
              Manager of <span class="text-primary font-semibold">southwesternrecording.com</span>
            </span>
            <ExternalLink className="h-4 w-4 text-muted-foreground group-hover:text-primary transition-colors shrink-0" />
          </a>

          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="#contact"
              class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-8 py-4 rounded-md font-semibold hover:bg-primary/90 transition-colors"
            >
              Get in Touch
              <ArrowRight className="h-5 w-5" />
            </a>
            <a
              href="#projects"
              class="inline-flex items-center justify-center gap-2 border border-input bg-background px-8 py-4 rounded-md font-semibold hover:bg-accent hover:text-accent-foreground transition-colors"
            >
              View Projects
            </a>
          </div>
        </div>

        <!-- Hero headshot -->
        <div class="hidden lg:flex justify-center">
          <div class="relative">
            <div class="w-80 h-80 xl:w-96 xl:h-96 rounded-2xl overflow-hidden border-2 border-primary/20 shadow-2xl shadow-primary/10">
              <img
                src="/headshot.jpg"
                alt="Nakul Tiruviluamala"
                class="w-full h-full object-cover object-top"
              />
            </div>
            <div class="absolute -bottom-3 -right-3 w-80 h-80 xl:w-96 xl:h-96 rounded-2xl border-2 border-primary/10 -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-24 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="relative">
          <div class="aspect-square rounded-2xl overflow-hidden border-2 border-primary/20 shadow-xl">
            <img
              src="/headshot.jpg"
              alt="Nakul Tiruviluamala"
              class="w-full h-full object-cover object-top"
              loading="lazy"
            />
          </div>
        </div>

        <div>
          <Badge variant="secondary" className="mb-4">
            About Me
          </Badge>
          <h2 class="text-3xl sm:text-4xl font-bold mb-6">
            Nakul Tiruviluamala
          </h2>
          <div class="space-y-4 text-muted-foreground text-lg leading-relaxed">
            {BIO.full.split('\n\n').map((paragraph) => (
              <p>{paragraph.trim()}</p>
            ))}
          </div>
          <div class="flex items-center gap-4 mt-8">
            <div class="flex items-center gap-2 text-muted-foreground">
              <MapPin className="h-5 w-5 text-primary" />
              <span>{SITE_CONFIG.location}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Expertise Section -->
  <section id="expertise" class="py-24 bg-card">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <Badge variant="accent" className="mb-4">
          What I Do
        </Badge>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Areas of Expertise</h2>
        <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
          A unique blend of artistic creativity and technical proficiency
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {EXPERTISE.map((category) => (
          <div class="space-y-6">
            <h3 class="text-xl font-semibold text-primary">{category.category}</h3>
            <div class="space-y-4">
              {category.skills.map((skill) => (
                <Card className="card-hover bg-background">
                  <CardHeader className="pb-2">
                    <CardTitle className="text-base">{skill.name}</CardTitle>
                  </CardHeader>
                  <CardContent>
                    <CardDescription>{skill.description}</CardDescription>
                  </CardContent>
                </Card>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Music Projects Section -->
  <section id="music" class="py-24 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <Badge variant="outline" className="mb-4">
          Music
        </Badge>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Music Projects</h2>
        <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
          Compositions, performances, and productions across genres
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {MUSIC_PROJECTS.map((project) => {
          const iconMap = { Film, Radio, Disc3, Mic };
          const Icon = iconMap[project.icon as keyof typeof iconMap];
          const Wrapper = project.url ? 'a' : 'div';
          return (
            <a
              href={project.url || undefined}
              target={project.url ? "_blank" : undefined}
              rel={project.url ? "noopener noreferrer" : undefined}
              class={`group flex items-start gap-5 p-6 rounded-xl bg-card border border-border hover:border-primary/50 transition-all card-hover ${!project.url ? 'cursor-default' : ''}`}
            >
              <div class="shrink-0 w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center">
                <Icon className="h-6 w-6 text-primary" />
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-[10px] font-semibold uppercase tracking-wider text-primary bg-primary/10 px-2 py-0.5 rounded-full">
                    {project.tag}
                  </span>
                </div>
                <div class="flex items-center justify-between mb-2">
                  <h3 class="font-semibold text-foreground group-hover:text-primary transition-colors">{project.title}</h3>
                  {project.url && <ExternalLink className="h-4 w-4 text-muted-foreground group-hover:text-primary transition-colors shrink-0" />}
                </div>
                <p class="text-sm text-muted-foreground leading-relaxed">
                  {project.description}
                </p>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Web Projects Section -->
  <section id="projects" class="py-24 bg-card">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <Badge variant="outline" className="mb-4">
          Portfolio
        </Badge>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Web Projects</h2>
        <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
          Websites and platforms I've designed and built
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {PROJECTS.map((project) => (
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col rounded-xl bg-card border border-border hover:border-primary/50 transition-all card-hover overflow-hidden"
          >
            <div class={`h-40 bg-gradient-to-br ${project.gradient} relative overflow-hidden`}>
              {project.thumbnail ? (
                <img
                  src={project.thumbnail}
                  alt={`${project.title} screenshot`}
                  class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <span class="text-3xl font-bold text-foreground/20 group-hover:text-foreground/40 transition-colors tracking-wider uppercase">
                    {project.title.split(' ').map((w: string) => w[0]).join('').slice(0, 3)}
                  </span>
                </div>
              )}
            </div>
            <div class="p-5 flex flex-col flex-1">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-[10px] font-semibold uppercase tracking-wider text-primary bg-primary/10 px-2 py-0.5 rounded-full">
                  {project.tag}
                </span>
              </div>
              <div class="flex items-center justify-between mb-1">
                <h3 class="font-semibold text-foreground group-hover:text-primary transition-colors">{project.title}</h3>
                <ExternalLink className="h-4 w-4 text-muted-foreground group-hover:text-primary transition-colors shrink-0" />
              </div>
              <p class="text-xs text-muted-foreground mb-3 leading-relaxed flex-1">
                {project.description}
              </p>
              <p class="text-[11px] text-muted-foreground/60 font-mono">
                {project.url.replace('https://', '')}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-24 bg-card">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center">
        <Badge variant="accent" className="mb-4">
          Get in Touch
        </Badge>
        <h2 class="text-3xl sm:text-4xl font-bold mb-6">
          Let's Create Something Together
        </h2>
        <p class="text-muted-foreground text-lg mb-8">
          Whether you're looking for collaboration on a music project, need audio engineering services,
          or want to discuss educational opportunities, I'd love to hear from you.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
          <a
            href={`mailto:${SITE_CONFIG.email}`}
            class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-8 py-4 rounded-md font-semibold hover:bg-primary/90 transition-colors w-full sm:w-auto"
          >
            <Mail className="h-5 w-5" />
            Send an Email
          </a>
        </div>

        <div class="p-6 rounded-xl bg-background border border-border">
          <div class="flex items-center justify-center gap-3 text-muted-foreground">
            <MapPin className="h-5 w-5 text-primary" />
            <span>{SITE_CONFIG.location}</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
